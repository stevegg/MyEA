# ── Build artifacts ───────────────────────────────────────────
dist/
build/

# ── Dependencies (installed fresh inside the image) ──────────
node_modules/

# ── Development / test files ─────────────────────────────────
*.test.ts
*.spec.ts
*.test.js
*.spec.js
__tests__/
test/
tests/
coverage/
.nyc_output/

# ── IDE and OS metadata ───────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Git ───────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── Environment files (never bake secrets into images) ────────
.env
.env.*
!.env.example

# ── Logs and runtime data ─────────────────────────────────────
logs/
*.log
volumes/

# ── Docker files (not needed inside the image) ────────────────
Dockerfile*
.dockerignore

# ── Documentation ─────────────────────────────────────────────
*.md
docs/

# ── TypeScript source maps (if emitted) ──────────────────────
*.js.map
*.d.ts.map

# ── Misc tooling ─────────────────────────────────────────────
.eslintcache
.prettiercache
.turbo/
