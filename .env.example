# ============================================================
# myEA — Personal AI Assistant — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── Node ────────────────────────────────────────────────────
NODE_ENV=development

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=myea
# IMPORTANT: Change this to a strong random password before deploying.
# Generate one with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=myea
# Full URL used by the backend (auto-assembled in docker-compose, override here for local dev)
DATABASE_URL=postgresql://myea:CHANGE_ME_STRONG_PASSWORD@localhost:5432/myea

# ── Auth (JWT) ───────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── Admin credentials ────────────────────────────────────────
ADMIN_USERNAME=admin
# Hash generated with: node -e "const b=require('bcryptjs');b.hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$12$replacethiswithyourbcrypthash

# ── AI Provider ──────────────────────────────────────────────
# Options: claude | openai | ollama
ACTIVE_AI_PROVIDER=claude
# Model name — examples: claude-opus-4-5, gpt-4o, llama3.2
AI_MODEL=claude-opus-4-5

ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
# Ollama runs as a sibling container; override for external Ollama
OLLAMA_BASE_URL=http://localhost:11434

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# ── Discord ──────────────────────────────────────────────────
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# ── Slack ────────────────────────────────────────────────────
SLACK_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# ── WhatsApp (Baileys) ───────────────────────────────────────
# First run will print a QR code to scan with your phone.
WHATSAPP_ENABLED=false

# ── Signal (via signal-cli-rest-api sidecar) ────────────────
SIGNAL_ENABLED=false
SIGNAL_PHONE_NUMBER=+1234567890
SIGNAL_CLI_URL=http://localhost:8080

# ── Gmail OAuth2 ─────────────────────────────────────────────
GMAIL_ENABLED=false
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3001/auth/gmail/callback
GMAIL_REFRESH_TOKEN=

# ── GitHub ───────────────────────────────────────────────────
GITHUB_ENABLED=false
GITHUB_TOKEN=

# ── Spotify ──────────────────────────────────────────────────
SPOTIFY_ENABLED=false
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3001/auth/spotify/callback
SPOTIFY_REFRESH_TOKEN=

# ── Smart Home (Home Assistant) ──────────────────────────────
SMART_HOME_ENABLED=false
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=

# ── Server ports ─────────────────────────────────────────────
BACKEND_PORT=3001
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

# ── Frontend build args (Vite) ───────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# ── Volume paths (inside container) ─────────────────────────
SKILLS_DIR=/app/volumes/skills
FILES_DIR=/app/volumes/files
LOGS_DIR=/app/volumes/logs
